<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft: Story Mode & Mojang Secrets</title>
    <style>
        /* Estilos Generales Inspirados en el Juego */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #1a110b; /* Marrón oscuro tipo tierra/madera */
            color: #f0f0f0;
            margin: 0;
            padding: 0;
            text-align: center;
        }

        header {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://images.unsplash.com/photo-1627856013091-fed6e4e30025?q=80&w=1000') center/cover;
            padding: 40px 20px;
            border-bottom: 5px solid #4a3b32;
        }

        h1 {
            color: #55ff55; /* Verde clásico de Minecraft */
            text-shadow: 3px 3px #000;
            font-size: 2.5rem;
            margin: 0;
        }

        .subtitle {
            color: #ffaa00; /* Dorado */
            font-weight: bold;
            text-shadow: 2px 2px #000;
        }

        /* Contenedor Principal */
        .container {
            max-width: 900px;
            margin: 30px auto;
            padding: 20px;
            background-color: #2e2218; /* Bloque de madera interna */
            border: 4px solid #4a3b32;
            border-radius: 8px;
            box-shadow: 0px 0px 15px rgba(0,0,0,0.5);
        }

        /* 1. SECCIÓN DE MENÚ INTERACTIVO (Pestañas) */
        .menu-tabs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .tab-button {
            background-color: #4a3b32;
            color: white;
            border: 2px solid #1a110b;
            padding: 12px 24px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1rem;
            transition: 0.2s;
        }

        .tab-button:hover, .tab-button.active {
            background-color: #55ff55;
            color: #000;
            border-color: #fff;
        }

        .tab-content {
            display: none;
            padding: 20px;
            background-color: #211710;
            border-radius: 5px;
            min-height: 200px;
        }

        .tab-content.active {
            display: block;
        }

        /* Estilos de las imágenes fijas dentro del contenido */
        .game-img {
            width: 100%;
            max-width: 500px;
            height: auto;
            margin-top: 15px;
            border: 3px solid #ffaa00;
            border-radius: 4px;
        }

        /* 2. SECCIÓN INTERACTIVA: Generador de Curiosidades Aleatorias */
        .curiosity-box {
            background-color: #3c2d23;
            padding: 20px;
            margin-top: 30px;
            border: 2px dashed #ffaa00;
            border-radius: 6px;
        }

        .action-btn {
            background-color: #ff5555; /* Rojo piedra rojiza */
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            border-radius: 4px;
            box-shadow: 0 4px #990000;
        }

        .action-btn:active {
            box-shadow: 0 2px #990000;
            transform: translateY(2px);
        }

        #curiosity-text {
            font-style: italic;
            font-size: 1.1rem;
            color: #ffff55;
            margin-top: 15px;
        }

        /* 3. SECCIÓN INTERACTIVA: Trivia Rápida */
        .trivia-box {
            margin-top: 30px;
            background-color: #1a110b;
            padding: 20px;
            border-radius: 6px;
        }

        .trivia-options button {
            background-color: #4a3b32;
            color: white;
            border: 1px solid #fff;
            padding: 10px 15px;
            margin: 5px;
            cursor: pointer;
        }

        .trivia-options button:hover {
            background-color: #ffaa00;
            color: black;
        }

        #trivia-result {
            margin-top: 10px;
            font-weight: bold;
        }

        footer {
            margin-top: 40px;
            padding: 20px;
            background-color: #110a06;
            color: #777;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <header>
        <h1>Minecraft: Story Mode</h1>
        <p class="subtitle">Explorando la Orden de la Piedra & los secretos de Mojang</p>
    </header>

    <div class="container">

        <div class="menu-tabs">
            <button class="tab-button active" onclick="openTab(event, 'story-mode')">Story Mode</button>
            <button class="tab-button" onclick="openTab(event, 'mojang')">Sobre Mojang</button>
            <button class="tab-button" onclick="openTab(event, 'wither-storm')">La Wither Storm</button>
        </div>

        <div id="story-mode" class="tab-content active">
            <h3>Una Aventura de Telltale Games</h3>
            <p>Lanzado en 2015, este juego llevó el universo de bloques a un formato narrativo episódico. Acompañamos a Jesse y sus amigos en una misión para salvar el mundo recreando a la legendaria "Orden de la Piedra".</p>
            <img src="https://images.unsplash.com/photo-1605899435973-ca2d1a8861cf?q=80&w=500" alt="Minecraft Vibe" class="game-img">
        </div>

        <div id="mojang" class="tab-content">
            <h3>Los Creadores del Fenómeno</h3>
            <p>Mojang Studios fue fundada en Suecia por Markus "Notch" Persson en 2009. Originalmente el juego se llamaba "Cave Game". En 2014, Microsoft compró la compañía por 2,500 millones de dólares.</p>
            <img src="https://images.unsplash.com/photo-1607604276583-eef5d076aa5f?q=80&w=500" alt="Gaming Setup" class="game-img">
        </div>

        <div id="wither-storm" class="tab-content">
            <h3>El Antagonista Supremo</h3>
            <p>La Wither Storm (Tormenta de Wither) es el monstruo principal de la primera temporada. Fue creada usando un bloque de comandos modificado acoplado a un Wither normal, consumiendo todo a su paso.</p>
            <img src="https://images.unsplash.com/photo-1579546929518-9e396f3cc809?q=80&w=500" alt="Abstract Storm Energy" class="game-img">
        </div>

        <hr style="border-color: #4a3b32; margin: 40px 0;">

        <div class="curiosity-box">
            <h3>¿Sabías qué...?</h3>
            <p>Presiona el botón para descubrir un dato curioso sobre el desarrollo del juego.</p>
            <button class="action-btn" onclick="showNewCuriosity()">¡Revelar Secreto!</button>
            <p id="curiosity-text">Haz clic arriba para empezar...</p>
        </div>

        <div class="trivia-box">
            <h3>Mini-Trivia: ¿Quién es el cerdo fiel de Jesse?</h3>
            <div class="trivia-options">
                <button onclick="checkAnswer(false)">Ruben Jr.</button>
                <button onclick="checkAnswer(true)">Reuben</button>
                <button onclick="checkAnswer(false)">Piggy</button>
            </div>
            <p id="trivia-result"></p>
        </div>

    </div>

    <footer>
        <p>Proyecto Expositivo — Creado con fines educativos.</p>
    </footer>

    <script>
        // 1. Lógica para el Menú de Pestañas
        function openTab(evt, tabName) {
            // Esconder todos los contenidos de pestaña
            let contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) {
                contents[i].classList.remove("active");
            }

            // Quitar la clase 'active' de todos los botones
            let buttons = document.getElementsByClassName("tab-button");
            for (let i = 0; i < buttons.length; i++) {
                buttons[i].classList.remove("active");
            }

            // Mostrar la pestaña actual y marcar el botón como activo
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }

        // 2. Lógica para las Curiosidades Aleatorias
        const curiosidades = [
            "Originalmente, Minecraft: Story Mode iba a llamarse 'Minecraft 2: Edición Narrativa'.",
            "La voz de Jesse masculino la hace Patton Oswalt, un famoso comediante y actor de Hollywood.",
            "A pesar de ser un juego de decisiones, el destino final de Reuben (el cerdo) no se puede cambiar en ninguna ruta.",
            "Mojang inicialmente rechazó la idea de un juego con historia, pero cambiaron de opinión al ver el éxito de Telltale con The Walking Dead.",
            "El Bloque de Comandos que da origen a la Wither Storm tiene una textura única que no existe en el Minecraft original."
        ];

        function showNewCuriosity() {
            // Selecciona un índice al azar dentro del array
            const randomIndex = Math.floor(Math.random() * curiosidades.length);
            // Reemplaza el texto en la interfaz web
            document.getElementById("curiosity-text").innerText = curiosidades[randomIndex];
        }

        // 3. Lógica para la Trivia
        function checkAnswer(isCorrect) {
            const resultParagraph = document.getElementById("trivia-result");
            if (isCorrect) {
                resultParagraph.innerText = "¡Correcto! 🐷 Reuben es el legendario y valiente cerdo de la historia.";
                resultParagraph.style.color = "#55ff55";
            } else {
                resultParagraph.innerText = "Incorrecto... ¡Inténtalo de nuevo! ❌";
                resultParagraph.style.color = "#ff5555";
            }
        }
    </script>
</body>
</html>
